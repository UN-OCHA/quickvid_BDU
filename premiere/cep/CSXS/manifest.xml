<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="org.unocha.branding"
                   ExtensionBundleVersion="0.40.5" ExtensionBundleName="OCHA QuickVid"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="org.unocha.branding.panel" Version="0.40.5"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="[14.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="8.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="org.unocha.branding.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Matches the DataViz plugin's CEF flag set EXACTLY. The enable-nodejs
                 flag powers the one-click auto-updater (js/auto-updater.js needs
                 https, fs and child_process). It was first tried in 0.34.0 and
                 Premiere crashed, but THAT manifest also carried allow-file-access and
                 disable-application-cache, which DataViz does not ship; the crash was
                 most likely that combination, not nodejs on its own. This is now the
                 minimal DataViz set. TEST ON A SPARE MACHINE after touching anything
                 here: a bad CEF flag makes Premiere crash on launch. If it does crash,
                 delete the enable-nodejs Parameter and the updater falls back to its
                 notify-only banner (still fully functional, just not one-click). -->
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>OCHA QuickVid</Menu>
          <Geometry><Size><Height>580</Height><Width>320</Width></Size></Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>

<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="org.unocha.branding"
                   ExtensionBundleVersion="0.39.2" ExtensionBundleName="OCHA QuickVid"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="org.unocha.branding.panel" Version="0.39.2"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="[14.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="8.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="org.unocha.branding.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--disable-application-cache</Parameter>
            <!-- DO NOT re-add the enable-nodejs CEF flag without testing it on a
                 spare machine first. It was added in 0.34.0 for the one-click updater
                 and Premiere began crashing; removing it is what stopped that. The
                 flag is fine in the DataViz plugin, but that runs in Illustrator, and
                 Premiere's CEP host is not the same. The updater already degrades to
                 notify-only when Node is absent, so the panel is fully functional
                 without it. -->
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>OCHA QuickVid</Menu>
          <Geometry><Size><Height>580</Height><Width>320</Width></Size></Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>

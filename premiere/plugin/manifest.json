{
  "manifestVersion": 5,
  "id": "org.unocha.quickvid.branding",
  "name": "OCHA Branding",
  "version": "0.5.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.6.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "ochaBrandingPanel",
      "label": { "default": "OCHA Branding" },
      "minimumSize": { "width": 230, "height": 320 },
      "maximumSize": { "width": 1200, "height": 2400 },
      "preferredDockedSize": { "width": 300, "height": 580 },
      "preferredFloatingSize": { "width": 300, "height": 580 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "plugin"
  },
  "icons": [
    { "width": 23, "height": 23, "path": "icons/panel.png", "scale": [1], "theme": ["all"], "species": ["generic"] },
    { "width": 46, "height": 46, "path": "icons/panel@2x.png", "scale": [2], "theme": ["all"], "species": ["generic"] }
  ]
}
